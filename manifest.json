{
  "manifest_version": 3,
  "name": "Match Report — Time Converter",
  "version": "1.4.0",
  "description": "Opens match report PDFs and converts event times (1T/2T/INT) to game minutes.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open match report PDF"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
